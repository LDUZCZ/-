rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isValidSession(data) {
      return data.userId == request.auth.uid &&
             data.startTime is string &&
             data.endTime is string &&
             data.duration is int &&
             data.duration >= 0 &&
             data.category in ['Work', 'Study', 'Exercise', 'Other'];
    }

    function isValidProfile(data) {
      return data.email is string;
    }

    // Sessions collection
    match /sessions/{sessionId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidSession(request.resource.data);
      allow update: if isAuthenticated() && isOwner(resource.data.userId) && isValidSession(request.resource.data);
      allow delete: if isAuthenticated() && isOwner(resource.data.userId);
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || request.auth.token.email == "lduzcz@163.com");
      allow write: if isOwner(userId) && isValidProfile(request.resource.data);
    }
  }
}
